<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/">

    <owl:Ontology rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/">
        <rdfs:label>Global Healthcare Ontology (By Sahir Maharaj)</rdfs:label>
        <rdfs:comment>An ontology by Sahir Maharaj representing the connected healthcare ecosystem</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Patient">
        <rdfs:label>Patient</rdfs:label>
        <rdfs:comment>A person receiving healthcare services</rdfs:comment>
        <ont:icon>🧍</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Clinician">
        <rdfs:label>Clinician</rdfs:label>
        <rdfs:comment>A healthcare professional involved in patient care</rdfs:comment>
        <ont:icon>🩺</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Doctor">
        <rdfs:label>Doctor</rdfs:label>
        <rdfs:comment>A physician responsible for diagnosis and treatment</rdfs:comment>
        <ont:icon>👨‍⚕️</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Radiologist">
        <rdfs:label>Radiologist</rdfs:label>
        <rdfs:comment>A specialist who interprets medical imaging</rdfs:comment>
        <ont:icon>🩻</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Specialist">
        <rdfs:label>Specialist</rdfs:label>
        <rdfs:comment>A specialist clinician consulted for complex cases</rdfs:comment>
        <ont:icon>🎯</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Technician">
        <rdfs:label>Technician</rdfs:label>
        <rdfs:comment>A professional operating imaging or diagnostic equipment</rdfs:comment>
        <ont:icon>🔧</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/CareTeam">
        <rdfs:label>CareTeam</rdfs:label>
        <rdfs:comment>A group of professionals assigned to a patient</rdfs:comment>
        <ont:icon>👥</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Hospital">
        <rdfs:label>Hospital</rdfs:label>
        <rdfs:comment>A healthcare facility providing inpatient and outpatient care</rdfs:comment>
        <ont:icon>🏥</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Clinic">
        <rdfs:label>Clinic</rdfs:label>
        <rdfs:comment>A smaller healthcare facility for consultations and basic care</rdfs:comment>
        <ont:icon>🏨</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Department">
        <rdfs:label>Department</rdfs:label>
        <rdfs:comment>A functional unit within a healthcare organisation</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Ward">
        <rdfs:label>Ward</rdfs:label>
        <rdfs:comment>An inpatient area where patients are admitted</rdfs:comment>
        <ont:icon>🛏️</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/EmergencyDepartment">
        <rdfs:label>EmergencyDepartment</rdfs:label>
        <rdfs:comment>A hospital department handling urgent and emergency cases</rdfs:comment>
        <ont:icon>🚨</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/IntensiveCareUnit">
        <rdfs:label>IntensiveCareUnit</rdfs:label>
        <rdfs:comment>A specialised ward for critically ill patients</rdfs:comment>
        <ont:icon>🫀</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/RadiologyDepartment">
        <rdfs:label>RadiologyDepartment</rdfs:label>
        <rdfs:comment>A department responsible for imaging workflows</rdfs:comment>
        <ont:icon>🩻</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/LaboratoryDepartment">
        <rdfs:label>LaboratoryDepartment</rdfs:label>
        <rdfs:comment>A department responsible for diagnostic testing</rdfs:comment>
        <ont:icon>🧪</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Pharmacy">
        <rdfs:label>Pharmacy</rdfs:label>
        <rdfs:comment>A unit dispensing and managing medication</rdfs:comment>
        <ont:icon>💊</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Bed">
        <rdfs:label>Bed</rdfs:label>
        <rdfs:comment>A hospital bed assigned to a patient</rdfs:comment>
        <ont:icon>🛏️</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Room">
        <rdfs:label>Room</rdfs:label>
        <rdfs:comment>A physical room within a healthcare facility</rdfs:comment>
        <ont:icon>🚪</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Appointment">
        <rdfs:label>Appointment</rdfs:label>
        <rdfs:comment>A scheduled meeting between patient and care provider</rdfs:comment>
        <ont:icon>📅</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Encounter">
        <rdfs:label>Encounter</rdfs:label>
        <rdfs:comment>A clinical interaction or care episode</rdfs:comment>
        <ont:icon>🤝</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Admission">
        <rdfs:label>Admission</rdfs:label>
        <rdfs:comment>An inpatient admission event</rdfs:comment>
        <ont:icon>📥</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Discharge">
        <rdfs:label>Discharge</rdfs:label>
        <rdfs:comment>A patient discharge event</rdfs:comment>
        <ont:icon>📤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Referral">
        <rdfs:label>Referral</rdfs:label>
        <rdfs:comment>A request to involve another clinician or facility</rdfs:comment>
        <ont:icon>➡️</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/FollowUp">
        <rdfs:label>FollowUp</rdfs:label>
        <rdfs:comment>A planned subsequent care interaction</rdfs:comment>
        <ont:icon>🔁</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Case">
        <rdfs:label>Case</rdfs:label>
        <rdfs:comment>A grouped clinical matter requiring tracking</rdfs:comment>
        <ont:icon>📁</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/TriageAssessment">
        <rdfs:label>TriageAssessment</rdfs:label>
        <rdfs:comment>An urgency assessment for patient prioritisation</rdfs:comment>
        <ont:icon>🚦</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/TriagePriority">
        <rdfs:label>TriagePriority</rdfs:label>
        <rdfs:comment>A priority level assigned to a case</rdfs:comment>
        <ont:icon>⚠️</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/CarePathway">
        <rdfs:label>CarePathway</rdfs:label>
        <rdfs:comment>A coordinated sequence of clinical steps</rdfs:comment>
        <ont:icon>🛤️</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/ClinicalProtocol">
        <rdfs:label>ClinicalProtocol</rdfs:label>
        <rdfs:comment>A formal clinical guideline or workflow</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/MedicalHistory">
        <rdfs:label>MedicalHistory</rdfs:label>
        <rdfs:comment>A patient history record</rdfs:comment>
        <ont:icon>📜</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/FamilyHistory">
        <rdfs:label>FamilyHistory</rdfs:label>
        <rdfs:comment>A record of health conditions among relatives</rdfs:comment>
        <ont:icon>👪</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Allergy">
        <rdfs:label>Allergy</rdfs:label>
        <rdfs:comment>A patient allergy or sensitivity</rdfs:comment>
        <ont:icon>🌿</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Medication">
        <rdfs:label>Medication</rdfs:label>
        <rdfs:comment>A medicine prescribed or administered</rdfs:comment>
        <ont:icon>💊</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Prescription">
        <rdfs:label>Prescription</rdfs:label>
        <rdfs:comment>An order authorising a medication</rdfs:comment>
        <ont:icon>📝</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/TreatmentPlan">
        <rdfs:label>TreatmentPlan</rdfs:label>
        <rdfs:comment>A planned set of interventions for a patient</rdfs:comment>
        <ont:icon>🧭</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Procedure">
        <rdfs:label>Procedure</rdfs:label>
        <rdfs:comment>A clinical procedure performed on a patient</rdfs:comment>
        <ont:icon>🔬</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Symptom">
        <rdfs:label>Symptom</rdfs:label>
        <rdfs:comment>A patient-reported or observed health issue</rdfs:comment>
        <ont:icon>🤒</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Diagnosis">
        <rdfs:label>Diagnosis</rdfs:label>
        <rdfs:comment>A clinical determination of disease or condition</rdfs:comment>
        <ont:icon>🧠</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/DifferentialDiagnosis">
        <rdfs:label>DifferentialDiagnosis</rdfs:label>
        <rdfs:comment>A possible diagnosis under consideration</rdfs:comment>
        <ont:icon>🔍</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Condition">
        <rdfs:label>Condition</rdfs:label>
        <rdfs:comment>A disease, disorder, injury, or abnormal state</rdfs:comment>
        <ont:icon>🧬</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/RiskFactor">
        <rdfs:label>RiskFactor</rdfs:label>
        <rdfs:comment>A factor increasing clinical risk</rdfs:comment>
        <ont:icon>⚠️</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/RiskProfile">
        <rdfs:label>RiskProfile</rdfs:label>
        <rdfs:comment>A combined patient risk representation</rdfs:comment>
        <ont:icon>📊</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/VitalSign">
        <rdfs:label>VitalSign</rdfs:label>
        <rdfs:comment>A physiological measurement</rdfs:comment>
        <ont:icon>❤️</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/LabTest">
        <rdfs:label>LabTest</rdfs:label>
        <rdfs:comment>A diagnostic laboratory test</rdfs:comment>
        <ont:icon>🧪</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/LabResult">
        <rdfs:label>LabResult</rdfs:label>
        <rdfs:comment>The result of a laboratory test</rdfs:comment>
        <ont:icon>📈</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Biomarker">
        <rdfs:label>Biomarker</rdfs:label>
        <rdfs:comment>A measurable biological indicator</rdfs:comment>
        <ont:icon>🧬</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/ImagingStudy">
        <rdfs:label>ImagingStudy</rdfs:label>
        <rdfs:comment>A medical imaging study event</rdfs:comment>
        <ont:icon>🩻</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/XRayStudy">
        <rdfs:label>XRayStudy</rdfs:label>
        <rdfs:comment>An X-ray imaging study</rdfs:comment>
        <ont:icon>🦴</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/CTStudy">
        <rdfs:label>CTStudy</rdfs:label>
        <rdfs:comment>A computed tomography study</rdfs:comment>
        <ont:icon>🌀</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/MRIStudy">
        <rdfs:label>MRIStudy</rdfs:label>
        <rdfs:comment>A magnetic resonance imaging study</rdfs:comment>
        <ont:icon>🧲</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/UltrasoundStudy">
        <rdfs:label>UltrasoundStudy</rdfs:label>
        <rdfs:comment>An ultrasound imaging study</rdfs:comment>
        <ont:icon>📡</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/MammographyStudy">
        <rdfs:label>MammographyStudy</rdfs:label>
        <rdfs:comment>A mammography imaging study</rdfs:comment>
        <ont:icon>🎗️</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/ImagingSeries">
        <rdfs:label>ImagingSeries</rdfs:label>
        <rdfs:comment>A collection of image frames within a study</rdfs:comment>
        <ont:icon>🖼️</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/ImageFrame">
        <rdfs:label>ImageFrame</rdfs:label>
        <rdfs:comment>A single image or slice</rdfs:comment>
        <ont:icon>🖼️</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/ScanRegion">
        <rdfs:label>ScanRegion</rdfs:label>
        <rdfs:comment>An anatomical region captured in imaging</rdfs:comment>
        <ont:icon>📍</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/AnatomicalStructure">
        <rdfs:label>AnatomicalStructure</rdfs:label>
        <rdfs:comment>A body structure referenced in care</rdfs:comment>
        <ont:icon>🧍</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Finding">
        <rdfs:label>Finding</rdfs:label>
        <rdfs:comment>An observed medical feature or abnormality</rdfs:comment>
        <ont:icon>🔎</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Abnormality">
        <rdfs:label>Abnormality</rdfs:label>
        <rdfs:comment>A finding outside expected normal appearance</rdfs:comment>
        <ont:icon>⚠️</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Fracture">
        <rdfs:label>Fracture</rdfs:label>
        <rdfs:comment>A break or crack in bone</rdfs:comment>
        <ont:icon>🦴</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Lesion">
        <rdfs:label>Lesion</rdfs:label>
        <rdfs:comment>An abnormal tissue region</rdfs:comment>
        <ont:icon>🔴</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Nodule">
        <rdfs:label>Nodule</rdfs:label>
        <rdfs:comment>A small rounded lesion</rdfs:comment>
        <ont:icon>🔴</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Mass">
        <rdfs:label>Mass</rdfs:label>
        <rdfs:comment>A larger abnormal tissue growth</rdfs:comment>
        <ont:icon>🧫</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/PneumoniaPattern">
        <rdfs:label>PneumoniaPattern</rdfs:label>
        <rdfs:comment>A radiological pattern compatible with pneumonia</rdfs:comment>
        <ont:icon>🫁</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/global-healthcare-ontology-by-sahir-maharaj/Cardiomegaly">
